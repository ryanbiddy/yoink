{
  "manifest_version": 3,
  "name": "Yoink",
  "short_name": "Yoink",
  "version": "2.0.0",
  "description": "Yoink any YouTube video into Claude or ChatGPT — full transcript, screenshots, and metadata in one structured doc.",
  "permissions": ["clipboardWrite", "notifications", "storage", "contextMenus", "activeTab", "offscreen"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://youtu.be/*",
    "http://127.0.0.1:5179/*",
    "http://localhost:5179/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16-light.png",
      "32": "icons/icon-32-light.png",
      "48": "icons/icon-48-light.png",
      "128": "icons/icon-128-light.png"
    }
  },
  "icons": {
    "16": "icons/icon-16-light.png",
    "32": "icons/icon-32-light.png",
    "48": "icons/icon-48-light.png",
    "128": "icons/icon-128-light.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*",
        "https://www.youtube.com/shorts/*",
        "https://m.youtube.com/watch*",
        "https://m.youtube.com/shorts/*"
      ],
      "js": ["lib/extract.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["yoink-memory.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
