{
  "manifest_version": 3,
  "name": "Yoink",
  "short_name": "Yoink",
  "version": "1.0.0",
  "description": "Yoink any YouTube video into Claude or ChatGPT — full transcript, screenshots, and metadata in one structured doc.",
  "permissions": ["clipboardWrite", "notifications", "storage", "contextMenus", "activeTab", "offscreen"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://youtu.be/*",
    "http://127.0.0.1:5179/*",
    "http://localhost:5179/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16-light.png",
      "32": "icons/icon-32-light.png",
      "48": "icons/icon-48-light.png",
      "128": "icons/icon-128-light.png"
    },
    "theme_icons": [
      { "size": 16, "light": "icons/icon-16-light.png", "dark": "icons/icon-16-dark.png" },
      { "size": 32, "light": "icons/icon-32-light.png", "dark": "icons/icon-32-dark.png" },
      { "size": 48, "light": "icons/icon-48-light.png", "dark": "icons/icon-48-dark.png" },
      { "size": 128, "light": "icons/icon-128-light.png", "dark": "icons/icon-128-dark.png" }
    ]
  },
  "icons": {
    "16": "icons/icon-16-light.png",
    "32": "icons/icon-32-light.png",
    "48": "icons/icon-48-light.png",
    "128": "icons/icon-128-light.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["lib/extract.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
